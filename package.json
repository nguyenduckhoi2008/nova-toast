{
  "name": "@nguyenkhoidev208/nova-toast",
  "version": "4.3.1",
  "description": "Lightweight toast notifications for React, Vue, Next, Nuxt — zero dependencies, animated, fully configurable",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tsup": "^8.4.0",
    "typescript": "^5"
  },
  "keywords": [
    "toast",
    "notification",
    "react",
    "vue",
    "next",
    "nuxt",
    "animated",
    "zero-dependency"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nguyenduckhoi2008/nova-toast"
  }
}
